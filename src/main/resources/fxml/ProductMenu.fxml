<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.control.cell.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.ProductController"
      spacing="12" prefWidth="620" prefHeight="500"
      style="-fx-background-color: #1e1e2e; -fx-padding: 24;">

    <Label text="🛍 Product Menu"
           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #cdd6f4;"/>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="tfSearch" promptText="Search by name or category…"
                   prefWidth="260" prefHeight="32"
                   style="-fx-background-color: #313244; -fx-text-fill: #cdd6f4; -fx-prompt-text-fill: #6c7086; -fx-background-radius: 6;"/>
        <Button text="Search" onAction="#onSearch" prefHeight="32"
                style="-fx-background-color: #89b4fa; -fx-font-weight: bold; -fx-background-radius: 6;"/>
        <Button text="Sort by Price ↑" onAction="#onSort" prefHeight="32"
                style="-fx-background-color: #cba6f7; -fx-font-weight: bold; -fx-background-radius: 6;"/>
        <Button text="Reset" onAction="#onReset" prefHeight="32"
                style="-fx-background-color: #585b70; -fx-text-fill: #cdd6f4; -fx-background-radius: 6;"/>
    </HBox>

    <TableView fx:id="tableProducts" VBox.vgrow="ALWAYS"
               style="-fx-background-color: #181825; -fx-border-color: #313244;">
        <columns>
            <TableColumn fx:id="colId"       text="ID"       prefWidth="55"/>
            <TableColumn fx:id="colName"     text="Name"     prefWidth="160"/>
            <TableColumn fx:id="colPrice"    text="Price"    prefWidth="100"/>
            <TableColumn fx:id="colStock"    text="Stock"    prefWidth="70"/>
            <TableColumn fx:id="colCategory" text="Category" prefWidth="110"/>
        </columns>
    </TableView>

    <HBox spacing="12" alignment="CENTER_LEFT">
        <Label text="Qty:" style="-fx-text-fill: #cdd6f4;"/>
        <TextField fx:id="tfQty" promptText="1" prefWidth="60" prefHeight="32"
                   style="-fx-background-color: #313244; -fx-text-fill: #cdd6f4; -fx-background-radius: 6;"/>
        <Button text="Add to Cart →" onAction="#onAddToCart" prefHeight="32"
                style="-fx-background-color: #a6e3a1; -fx-font-weight: bold; -fx-background-radius: 6;"/>
        <Label fx:id="lblCart" text="" style="-fx-text-fill: #a6e3a1; -fx-font-size: 11px;"/>
    </HBox>

    <Button text="← Back" onAction="#onBack"
            style="-fx-background-color: transparent; -fx-text-fill: #a6adc8; -fx-underline: true;"/>
</VBox>
