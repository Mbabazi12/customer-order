<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.ManagerOrdersController"
      spacing="12" prefWidth="700" prefHeight="500"
      style="-fx-background-color: #1e1e2e; -fx-padding: 24;">

    <Label text="📦 All Orders"
           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #cdd6f4;"/>

    <TableView fx:id="tableOrders" VBox.vgrow="ALWAYS"
               style="-fx-background-color: #181825; -fx-border-color: #313244;">
        <columns>
            <TableColumn fx:id="colOrderId"  text="Order ID"  prefWidth="80"/>
            <TableColumn fx:id="colCustomer" text="Customer"  prefWidth="130"/>
            <TableColumn fx:id="colProduct"  text="Product"   prefWidth="140"/>
            <TableColumn fx:id="colQty"      text="Qty"       prefWidth="55"/>
            <TableColumn fx:id="colPayment"  text="Payment"   prefWidth="110"/>
            <TableColumn fx:id="colTotal"    text="Total"     prefWidth="90"/>
            <TableColumn fx:id="colStatus"   text="Status"    prefWidth="90"/>
        </columns>
    </TableView>

    <HBox spacing="12" alignment="CENTER_LEFT">
        <Label text="New Status:" style="-fx-text-fill: #cdd6f4;"/>
        <ComboBox fx:id="cbStatus" prefWidth="140"
                  style="-fx-background-color: #313244; -fx-background-radius: 6;"/>
        <Button text="Update Selected" onAction="#onUpdateStatus" prefHeight="34"
                style="-fx-background-color: #fab387; -fx-font-weight: bold; -fx-background-radius: 6;"/>
        <Label fx:id="lblMsg" text="" style="-fx-text-fill: #a6e3a1; -fx-font-size: 12px;"/>
    </HBox>

    <Button text="← Back" onAction="#onBack"
            style="-fx-background-color: transparent; -fx-text-fill: #a6adc8; -fx-underline: true;"/>
</VBox>
