<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.OrderController"
      alignment="CENTER" spacing="16"
      prefWidth="420" prefHeight="420"
      style="-fx-background-color: #1e1e2e; -fx-padding: 36;">

    <Label text="🛒 Place New Order"
           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #cdd6f4;"/>

    <GridPane hgap="12" vgap="12" alignment="CENTER">
        <Label text="Product ID:" GridPane.columnIndex="0" GridPane.rowIndex="0"
               style="-fx-text-fill: #cdd6f4;"/>
        <TextField fx:id="tfProductId" promptText="e.g. 101" prefWidth="200"
                   GridPane.columnIndex="1" GridPane.rowIndex="0"
                   style="-fx-background-color: #313244; -fx-text-fill: #cdd6f4; -fx-background-radius: 6;"/>

        <Label text="Quantity:" GridPane.columnIndex="0" GridPane.rowIndex="1"
               style="-fx-text-fill: #cdd6f4;"/>
        <TextField fx:id="tfQuantity" promptText="e.g. 2" prefWidth="200"
                   GridPane.columnIndex="1" GridPane.rowIndex="1"
                   style="-fx-background-color: #313244; -fx-text-fill: #cdd6f4; -fx-background-radius: 6;"/>

        <Label text="Payment:" GridPane.columnIndex="0" GridPane.rowIndex="2"
               style="-fx-text-fill: #cdd6f4;"/>
        <ComboBox fx:id="cbPayment" prefWidth="200"
                  GridPane.columnIndex="1" GridPane.rowIndex="2"
                  style="-fx-background-color: #313244; -fx-background-radius: 6;"/>
    </GridPane>

    <Label fx:id="lblSummary" text="" wrapText="true" prefWidth="320"
           style="-fx-text-fill: #a6e3a1; -fx-font-size: 12px;"/>

    <Label fx:id="lblError" text="" wrapText="true" prefWidth="320"
           style="-fx-text-fill: #f38ba8; -fx-font-size: 12px;"/>

    <HBox spacing="14" alignment="CENTER">
        <Button text="💳 Pay Now" onAction="#onPayNow" prefWidth="130" prefHeight="38"
                style="-fx-background-color: #a6e3a1; -fx-font-weight: bold; -fx-background-radius: 8;"/>
        <Button text="Cancel"    onAction="#onCancel" prefWidth="100" prefHeight="38"
                style="-fx-background-color: #f38ba8; -fx-font-weight: bold; -fx-background-radius: 8;"/>
    </HBox>
</VBox>
