<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.CancelOrderController"
      spacing="14" prefWidth="560" prefHeight="440"
      style="-fx-background-color: #1e1e2e; -fx-padding: 24;">

    <Label text="❌ Cancel Pending Order"
           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #cdd6f4;"/>

    <Label text="Select a pending order below and click Cancel Order."
           style="-fx-text-fill: #a6adc8; -fx-font-size: 12px;"/>

    <TableView fx:id="tablePending" VBox.vgrow="ALWAYS"
               style="-fx-background-color: #181825; -fx-border-color: #313244;">
        <columns>
            <TableColumn fx:id="colOrderId" text="Order ID" prefWidth="80"/>
            <TableColumn fx:id="colProduct" text="Product"  prefWidth="160"/>
            <TableColumn fx:id="colQty"     text="Qty"      prefWidth="60"/>
            <TableColumn fx:id="colTotal"   text="Total"    prefWidth="100"/>
            <TableColumn fx:id="colStatus"  text="Status"   prefWidth="100"/>
        </columns>
    </TableView>

    <HBox spacing="12" alignment="CENTER_LEFT">
        <Button text="❌ Cancel Selected Order" onAction="#onCancelSelected" prefHeight="36"
                style="-fx-background-color: #f38ba8; -fx-font-weight: bold; -fx-background-radius: 8;"/>
        <Label fx:id="lblMsg" text="" style="-fx-text-fill: #a6e3a1; -fx-font-size: 12px;"/>
    </HBox>

    <Button text="← Back" onAction="#onBack"
            style="-fx-background-color: transparent; -fx-text-fill: #a6adc8; -fx-underline: true;"/>
</VBox>
