<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.MyOrdersController"
      spacing="12" prefWidth="640" prefHeight="480"
      style="-fx-background-color: #1e1e2e; -fx-padding: 24;">

    <Label text="📋 My Orders"
           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #cdd6f4;"/>

    <HBox spacing="10">
        <Button text="All"       onAction="#onAll"       prefHeight="30"
                style="-fx-background-color: #585b70; -fx-text-fill: #cdd6f4; -fx-background-radius: 6;"/>
        <Button text="Pending"   onAction="#onPending"   prefHeight="30"
                style="-fx-background-color: #f9e2af; -fx-font-weight: bold; -fx-background-radius: 6;"/>
        <Button text="Delivered" onAction="#onDelivered" prefHeight="30"
                style="-fx-background-color: #a6e3a1; -fx-font-weight: bold; -fx-background-radius: 6;"/>
    </HBox>

    <TableView fx:id="tableOrders" VBox.vgrow="ALWAYS"
               style="-fx-background-color: #181825; -fx-border-color: #313244;">
        <columns>
            <TableColumn fx:id="colOrderId"  text="Order ID" prefWidth="80"/>
            <TableColumn fx:id="colProduct"  text="Product"  prefWidth="150"/>
            <TableColumn fx:id="colQty"      text="Qty"      prefWidth="60"/>
            <TableColumn fx:id="colPayment"  text="Payment"  prefWidth="110"/>
            <TableColumn fx:id="colTotal"    text="Total"    prefWidth="100"/>
            <TableColumn fx:id="colStatus"   text="Status"   prefWidth="100"/>
        </columns>
    </TableView>

    <Button text="← Back" onAction="#onBack"
            style="-fx-background-color: transparent; -fx-text-fill: #a6adc8; -fx-underline: true;"/>
</VBox>
